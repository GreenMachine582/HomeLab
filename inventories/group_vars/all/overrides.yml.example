---
# inventories/group_vars/all/overrides.yml.example
# Template for overrides.yml — copy and fill in real values before running Ansible.
#
#   cp inventories/group_vars/all/overrides.yml.example \
#      inventories/group_vars/all/overrides.yml
#
# overrides.yml is gitignored. This example file is committed as a reference.

lan_subnet: "EDIT_BEFORE_USE"   # e.g. 192.168.1.0/24

# GitHub org/username the homelab repo lives under — git@github.com:<github_org>/homelab.git.
# Not a secret; needed before Infisical/vault.yml are reachable (repo clone), so
# it lives here rather than in vault.yml. See CLAUDE.md "Secrets".
github_org: "EDIT_BEFORE_USE"   # e.g. your-github-username-or-org

ip_edge:    "EDIT_BEFORE_USE"   # homelab-edge static DHCP IP
ip_observe: "EDIT_BEFORE_USE"   # homelab-observe static DHCP IP
ip_svc_01:  "EDIT_BEFORE_USE"   # homelab-svc-01 static DHCP IP
ip_svc_02:  "EDIT_BEFORE_USE"   # homelab-svc-02 static DHCP IP
ip_svc_03:  "EDIT_BEFORE_USE"   # homelab-svc-03 static DHCP IP

ssh_port: 22   # SSH port for all hosts (default: 22)
