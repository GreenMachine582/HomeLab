{{ ansible_managed | comment }}
#
# Infisical operational secrets — node-generated, NEVER committed, NEVER copied
# to the WSL vault.yml. Lives at {{ infisical_data_dir }}/.env (mode 0600).
# Shared via env_file by infisical, infisical-db, and infisical-redis — each
# image picks out only the keys it recognises (see docker-compose.edge.yml).
#
# Origin of each value (see roles/infisical/tasks/main.yml):
#   *_PASSWORD / AUTH_SECRET — generated ONCE on this node with `openssl rand`,
#     then read back from this file on every subsequent run so they are never
#     regenerated/rotated by accident (mirrors the seed task's "additive,
#     create-if-absent" philosophy, applied to node-local secrets).
#   ENCRYPTION_KEY — the ONE value sourced from the WSL vault.yml
#     (vault_infisical_encryption_key). PERMANENT — do not change in place; a
#     changed key cannot decrypt the existing Postgres volume. Rotation requires
#     Infisical's documented key-rotation procedure (see docs/TROUBLESHOOTING.md).
#
# To change DB/Redis/auth secrets post-deploy: edit this file directly on the
# node, then `docker compose -f docker-compose.edge.yml up -d infisical
# infisical-db infisical-redis` to pick up the change. Document in
# docs/TROUBLESHOOTING.md.
#
# ⚠️  Verify this variable set against the deployed Infisical version's
# self-hosting docs before first run — names have changed across major versions.

# ── Consumed by the infisical app container ──────────────────────────────────
ENCRYPTION_KEY={{ vault_infisical_encryption_key }}
AUTH_SECRET={{ infisical_auth_secret }}
SITE_URL={{ infisical_site_url }}
DB_CONNECTION_URI=postgresql://{{ infisical_db_user }}:{{ infisical_db_password }}@infisical-db:5432/{{ infisical_db_name }}
REDIS_URL=redis://default:{{ infisical_redis_password }}@infisical-redis:{{ infisical_redis_port }}

# ── Consumed by infisical-db (postgres official image env vars) ──────────────
POSTGRES_USER={{ infisical_db_user }}
POSTGRES_PASSWORD={{ infisical_db_password }}
POSTGRES_DB={{ infisical_db_name }}

# ── Consumed by infisical-redis (read by the entrypoint shell, see compose) ──
REDIS_PASSWORD={{ infisical_redis_password }}
