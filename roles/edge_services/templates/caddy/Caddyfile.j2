{# roles/edge_services/templates/caddy/Caddyfile.j2 #}
{
    # HTTP-only — .homelab.local is not a public domain; ACME certificates unavailable.
    # To enable internal TLS with a self-signed CA install: replace auto_https off with tls internal,
    # then import the Caddy root CA into your browsers/devices.
    auto_https off
    admin off
}

{% for route in caddy_routes %}
http://{{ route.hostname }} {
    reverse_proxy {{ route.upstream }}
}
{% endfor %}
