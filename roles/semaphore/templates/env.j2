{{ ansible_managed | comment }}
#
# Semaphore operational secrets — node-generated + vault-seeded, NEVER committed.
# Lives at {{ semaphore_data_dir }}/.env (mode 0600). Shared via env_file by
# semaphore and semaphore-db (see docker-compose.edge.yml).
#
# Origin of each value (see roles/semaphore/tasks/main.yml):
#   POSTGRES_PASSWORD — generated ONCE on this node with `openssl rand`, then
#     read back from this file on every subsequent run — never rotated out from
#     under the running stack by a re-deploy.
#   SEMAPHORE_ADMIN / SEMAPHORE_ADMIN_PASSWORD — sourced from the WSL vault.yml
#     (vault_semaphore_admin_{user,password}). Semaphore comes up during Phase 1,
#     before Infisical is seeded, so its bootstrap admin account can't be a
#     runtime Infisical lookup — a deliberate bootstrap-tier exception (see the
#     "[bootstrap]" section of vault.yml.example).
#   INFISICAL_UNIVERSAL_AUTH_CLIENT_{ID,SECRET} — the READ-ONLY runtime machine
#     identity (vault_infisical_runtime_client_{id,secret}). NEVER inject the
#     bootstrap/write identity here — a leaked runtime token can only read
#     secrets, never create/overwrite/delete them.
#
# To change the admin password or DB password post-deploy: edit this file
# directly on the node, then `docker compose -f docker-compose.edge.yml up -d
# semaphore semaphore-db`. Document the change in docs/TROUBLESHOOTING.md.
#
# ⚠️  Verify INFISICAL_UNIVERSAL_AUTH_CLIENT_* names against the Infisical
# Ansible collection / Semaphore secret-storage integration docs before first
# run — Semaphore's native Infisical support and variable names may differ by
# version; this assumes Universal Auth (machine identity) client credentials.

# ── Consumed by the semaphore app container ──────────────────────────────────
SEMAPHORE_DB_USER={{ semaphore_db_user }}
SEMAPHORE_DB_PASS={{ semaphore_db_password }}
SEMAPHORE_ADMIN={{ vault_semaphore_admin_user }}
SEMAPHORE_ADMIN_PASSWORD={{ vault_semaphore_admin_password }}
SEMAPHORE_ADMIN_EMAIL={{ semaphore_admin_email }}

INFISICAL_UNIVERSAL_AUTH_CLIENT_ID={{ vault_infisical_runtime_client_id }}
INFISICAL_UNIVERSAL_AUTH_CLIENT_SECRET={{ vault_infisical_runtime_client_secret }}

# ── Consumed by semaphore-db (postgres official image env vars) ──────────────
POSTGRES_USER={{ semaphore_db_user }}
POSTGRES_PASSWORD={{ semaphore_db_password }}
POSTGRES_DB={{ semaphore_db_name }}
