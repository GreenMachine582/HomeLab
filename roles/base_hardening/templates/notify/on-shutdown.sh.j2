#!/bin/bash
# Rendered by Ansible — do not edit directly on the host.
# Source: roles/base_hardening/templates/notify/on-shutdown.sh.j2
set -euo pipefail

HOST="{{ inventory_hostname }}"
TIME=$(date "+%Y-%m-%d %H:%M:%S")
MSG="$HOST is shutting down at $TIME"

shoutrrr send --url "{{ notify_ntfy_shoutrrr_url }}" --message "$MSG" \
|| shoutrrr send --url "{{ notify_discord_shoutrrr_url }}" --message "[Shutdown] $MSG"
