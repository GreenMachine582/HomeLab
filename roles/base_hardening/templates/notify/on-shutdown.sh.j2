#!/bin/bash
# Rendered by Ansible — do not edit directly on the host.
# Source: roles/base_hardening/templates/notify/on-shutdown.sh.j2
set -euo pipefail

HOST="{{ inventory_hostname }}"
TIME=$(date "+%Y-%m-%d %H:%M:%S")
MSG="$HOST is shutting down at $TIME"

curl -sf \
  -H "Authorization: Bearer {{ notify_ntfy_token }}" \
  -H "Title: {{ inventory_hostname }} shutting down" \
  -H "Priority: high" \
  -H "Tags: warning" \
  -d "$MSG" \
  "{{ notify_ntfy_url }}" > /dev/null \
|| curl -sf \
  -H "Content-Type: application/json" \
  --data-raw "{\"content\": \"⚠️ [Shutdown] $MSG\"}" \
  "{{ notify_discord_webhook }}" > /dev/null || true
