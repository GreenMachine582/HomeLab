#!/bin/bash
# Rendered by Ansible — do not edit directly on the host.
# Source: roles/base_hardening/templates/notify/on-boot.sh.j2
set -euo pipefail

HOST="{{ inventory_hostname }}"
TIME=$(date "+%Y-%m-%d %H:%M:%S")
MSG="$HOST booted at $TIME"

curl -sf \
  -H "Authorization: Bearer {{ notify_ntfy_token }}" \
  -H "Title: {{ inventory_hostname }} booted" \
  -H "Priority: default" \
  -H "Tags: white_check_mark" \
  -d "$MSG" \
  "{{ notify_ntfy_url }}" > /dev/null \
|| curl -sf \
  -H "Content-Type: application/json" \
  --data-raw "{\"content\": \"✅ [Boot] $MSG\"}" \
  "{{ notify_discord_webhook }}" > /dev/null || true
