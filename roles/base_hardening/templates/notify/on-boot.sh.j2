#!/bin/bash
# Rendered by Ansible — do not edit directly on the host.
# Source: roles/base_hardening/templates/notify/on-boot.sh.j2
set -euo pipefail

HOST="{{ inventory_hostname }}"
TIME=$(date "+%Y-%m-%d %H:%M:%S")
TITLE="Boot: $HOST"
MSG="$HOST booted at $TIME"

# Try ntfy first; fall back to shoutrrr → Discord if observe is unreachable.
if curl -sf \
    -H "Authorization: Bearer {{ vault_ntfy_token }}" \
    -H "Title: $TITLE" \
    -H "Tags: white_check_mark" \
    -d "$MSG" \
    "{{ notify_ntfy_url }}"; then
    exit 0
fi

shoutrrr send --url "{{ vault_shoutrrr_discord_alerts }}" --message "[$TITLE] $MSG"
