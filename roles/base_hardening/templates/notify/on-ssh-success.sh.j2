#!/bin/bash
# Rendered by Ansible — do not edit directly on the host.
# Source: roles/base_hardening/templates/notify/on-ssh-success.sh.j2
# Persistent daemon: watches journalctl for accepted SSH logins and notifies.
set -euo pipefail

HOST="{{ inventory_hostname }}"

notify() {
    local user="$1" ip="$2" time="$3"
    local msg="$user logged in to $HOST from $ip at $time"

    curl -sf \
      -H "Authorization: Bearer {{ notify_ntfy_token }}" \
      -H "Title: SSH login on {{ inventory_hostname }}" \
      -H "Priority: high" \
      -H "Tags: key" \
      -d "$msg" \
      "{{ notify_ntfy_url }}" > /dev/null \
    || curl -sf \
      -H "Content-Type: application/json" \
      --data-raw "{\"content\": \"🔑 [SSH Login] $msg\"}" \
      "{{ notify_discord_webhook }}" > /dev/null || true
}

journalctl -fu ssh --output=cat | while read -r line; do
    if echo "$line" | grep -q "Accepted"; then
        USER=$(echo "$line" | grep -oP 'for \K\S+')
        # Skip Ansible automation user — it SSHes for every task, causing notification spam.
        [[ "$USER" == "homelab" ]] && continue
        IP=$(echo "$line"   | grep -oP 'from \K\S+')
        TIME=$(date "+%Y-%m-%d %H:%M:%S")
        notify "$USER" "$IP" "$TIME"
    fi
done
