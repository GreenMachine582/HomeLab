# Rendered by Ansible — do not edit directly on the host.
[Unit]
Description=Notify on system shutdown
DefaultDependencies=no
Before=shutdown.target reboot.target halt.target

[Service]
Type=oneshot
ExecStart={{ notify_script_dir }}/on-shutdown.sh
TimeoutStartSec=15

[Install]
WantedBy=halt.target reboot.target poweroff.target
