# n8n non-secret config
# Rendered by Ansible — do not edit directly on the host.
N8N_HOST={{ n8n_host }}
N8N_PORT={{ n8n_port }}
N8N_PROTOCOL={{ n8n_protocol }}
N8N_WEBHOOK_URL={{ n8n_webhook_url }}
WEBHOOK_URL={{ n8n_webhook_url }}
GENERIC_TIMEZONE={{ timezone }}
TZ={{ timezone }}
N8N_LOG_LEVEL={{ n8n_log_level }}
DB_SQLITE_POOL_SIZE={{ n8n_db_sqlite_pool_size }}
N8N_RUNNERS_ENABLED={{ n8n_runners_enabled | lower }}
N8N_BLOCK_ENV_ACCESS_IN_NODE={{ n8n_block_env_access_in_node | lower }}
N8N_GIT_NODE_DISABLE_BARE_REPOS={{ n8n_git_node_disable_bare_repos | lower }}
N8N_USER_MANAGEMENT_DISABLED={{ n8n_user_management_disabled | lower }}