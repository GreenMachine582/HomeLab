###############################################
# ansible ENV TEMPLATE
# Copy to:
#   .env        for non-secret config
#   .env.secret for secrets (gitignored)
###############################################

# ---- Non-sensitive (goes to: .env) ----

# ---- Sensitive (goes to: .env.secret, DO NOT COMMIT) ----
# EDGE_IP=192.168.xx.xxx
# OBSERVE_IP=192.168.xx.xxx
# SVC01_IP=192.168.xx.xxx
# SSH_KEY=~/.ssh/homelab-edge
# SSH_KEY_PASSPHRASE='your_passphrase_here'
